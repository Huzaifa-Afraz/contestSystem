model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String
  password  String
  role      Role     @default(NORMAL)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  participations Participation[]
  prizes Prize[]

  @@map("users")
}

enum Role {
  NORMAL
  VIP
  ADMIN
}